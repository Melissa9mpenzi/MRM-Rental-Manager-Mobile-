{
  "buildCommand": "bash scripts/vercel-build-web.sh",
  "outputDirectory": "build/web",
  "framework": null,
  "build": {
    "env": {
      "API_BASE_URL": "https://mrm-rental-manager-backend.vercel.app",
      "SUI_NETWORK": "testnet",
      "SUI_RPC_URL": "https://fullnode.testnet.sui.io:443",
      "SUI_EXPLORER_BASE": "https://suiscan.xyz/testnet"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
